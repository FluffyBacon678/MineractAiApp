# ── Minecraft server ────────────────────────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.21.1
BOT_USERNAME=Bud

# ── Ollama (local LLM — always available) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=20000

# ── OpenAI (optional — leave blank to disable) ──────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000

# ── Hybrid AI routing ────────────────────────────────────────────────────────
# dialogue_provider: ollama | openai | hybrid
DIALOGUE_PROVIDER=hybrid
# intent_provider: ollama | openai  (ollama recommended — faster, cheaper)
INTENT_PROVIDER=ollama
# hybrid_strategy: quality_routing | openai_primary | ollama_primary | round_robin
HYBRID_STRATEGY=quality_routing
# Max OpenAI calls per hour (cost guard)
OPENAI_HOURLY_LIMIT=30

# ── Companion ────────────────────────────────────────────────────────────────
COMPANION_NAME=Bud
OBSERVE_INTERVAL_MS=10000
TALKATIVE_INTERVAL_MS=45000
FOLLOW_DISTANCE=3
LOITER_RADIUS=8
RESPONSE_DELAY_MS=1500
